# LEXGUARD runtime configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-2.5-flash

# Google Document AI OCR for PDF/image extraction.
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_TIMEOUT_MS=20000
MAX_UPLOAD_BYTES=8000000

# Local mode is deterministic and runs with no cloud credentials.
# Set AI_PROVIDER=openai to add a GPT-5.5 review layer.
# Set AI_PROVIDER=vertex to add a Gemini review layer through Vertex AI.
AI_PROVIDER=local

# OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_MS=12000
OPENAI_CHAT_TIMEOUT_MS=10000

# Optional when running locally without Application Default Credentials.
# GOOGLE_OAUTH_ACCESS_TOKEN=ya29...

PORT=8080
